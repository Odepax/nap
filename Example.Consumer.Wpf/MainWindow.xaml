<Window x:Class="Example.Consumer.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Example.Consumer.Wpf"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
	<Window.Resources>
		<local:UpperConverter x:Key="UpperConverter"/>
	</Window.Resources>
	
    <StackPanel Orientation="Vertical">
		<TextBlock Text="Id" Margin="8"/>
		<Slider Minimum="1" Maximum="100" Value="{ Binding Id, Mode=OneWayToSource, UpdateSourceTrigger=PropertyChanged }"/>

		<TextBlock Text="Name" Margin="8"/>
		<TextBox Text="{ Binding Name, Mode=OneWayToSource, UpdateSourceTrigger=PropertyChanged }"/>
		
		<TextBlock Text="Upper name:" Margin="8"/>
		<TextBlock Text="{ Binding Name, Mode=OneWay, Converter={StaticResource UpperConverter} }"/>
    </StackPanel>
</Window>
